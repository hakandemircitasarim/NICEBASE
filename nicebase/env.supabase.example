# Local-only helper for "one command publish" to Supabase Cloud via CLI.
# Do NOT commit your real token. Keep `.env.supabase` local.
#
# 1) Copy this file to `.env.supabase`
# 2) Fill values
# 3) Run: npm run db:publish

# Find this in Supabase Dashboard (Project Settings or URL): project ref (xxxxxx)
SUPABASE_PROJECT_REF=

# Create an access token: Supabase Dashboard -> Account -> Access Tokens
SUPABASE_ACCESS_TOKEN=
