# NICEBASE - Environment template
#
# Create your real `.env` next to this file.
#
# Windows (PowerShell):
#   Copy-Item .\env.example .\.env
#
# macOS/Linux:
#   cp env.example .env
#
# IMPORTANT:
# - Changing these values DOES NOT require a database reset.
# - You usually only need to restart the dev server (npm run dev).

# Which environment are we pointing to? (optional)
# local | cloud | prod
VITE_APP_ENV=local

# -----------------------------
# Supabase (Cloud sync + Auth)
# -----------------------------
#
# Option A) LOCAL Supabase (Docker) via Supabase CLI
# 1) Run: npx supabase start
# 2) Run: npx supabase status  -> copy "API URL" and "anon key"
#
# Example:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....
#
# Option B) HOSTED Supabase (Supabase Cloud)
# 1) Create a project on https://supabase.com
# 2) Settings -> API -> copy Project URL + anon public key
# Example:
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------
# Google OAuth (Native Sign-In)
# -----------------------------
# Required for native Android/iOS Google Sign-In (bottom sheet, no browser).
# Get this from Google Cloud Console → APIs & Services → Credentials
# → OAuth 2.0 Client IDs → Web application → Client ID
# This is the SAME client ID used in Supabase Dashboard → Auth → Google provider.
VITE_GOOGLE_WEB_CLIENT_ID=

# -----------------------------
# OpenAI (optional - Aiya page)
# -----------------------------
# If empty, AI assistant features may be disabled or show an error.
VITE_OPENAI_API_KEY=


